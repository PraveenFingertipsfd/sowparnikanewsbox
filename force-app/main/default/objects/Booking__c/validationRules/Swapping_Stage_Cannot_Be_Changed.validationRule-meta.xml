<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Swapping_Stage_Cannot_Be_Changed</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
ISPICKVAL(PRIORVALUE(Stage__c), &quot;Swapping Completed&quot;),
NOT(ISPICKVAL(Stage__c, &quot;Swapping Completed&quot;))
)</errorConditionFormula>
    <errorMessage>Swapped booking stage cannot be changed</errorMessage>
</ValidationRule>
