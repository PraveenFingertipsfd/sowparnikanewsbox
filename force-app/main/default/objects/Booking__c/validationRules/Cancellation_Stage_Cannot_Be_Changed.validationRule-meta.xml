<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cancellation_Stage_Cannot_Be_Changed</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    ISPICKVAL(PRIORVALUE(Stage__c), &quot;Cancellation&quot;),
    NOT(ISPICKVAL(Stage__c, &quot;Cancellation&quot;))
)</errorConditionFormula>
    <errorMessage>Cancellation Booking stage cannot be changed</errorMessage>
</ValidationRule>
