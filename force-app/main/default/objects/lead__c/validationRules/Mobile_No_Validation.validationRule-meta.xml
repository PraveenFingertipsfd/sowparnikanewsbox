<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Mobile_No_Validation</fullName>
    <active>false</active>
    <errorConditionFormula>AND(NOT(ISBLANK( Phone__c  )),NOT(REGEX(Phone__c , &quot;(\\d){10}&quot;)))</errorConditionFormula>
    <errorDisplayField>Phone__c</errorDisplayField>
    <errorMessage>Please enter Valid Mobile Number</errorMessage>
</ValidationRule>
