<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Follow_Up_Date_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>AND( ISPICKVAL( Lead_status__c ,&apos;Follow Up&apos;),  ISNULL(Next_follow_up_Date__c ))</errorConditionFormula>
    <errorDisplayField>Next_follow_up_Date__c</errorDisplayField>
    <errorMessage>Please Enter Next Follow Up date</errorMessage>
</ValidationRule>
