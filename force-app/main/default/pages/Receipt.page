                    <p><strong><center><u>AGREEMENT FOR SALE</u></center></strong></p>
                    
                    <p class="noalign">This Agreement for Sale (&ldquo;<strong>Agreement</strong>&rdquo;) is executed on this 
                        <apex:outputText rendered="{!if((DAY(TODAY()) == 1) || (DAY(TODAY()) == 21) || (DAY(TODAY()) == 31) , true,false) }"> <span class="highlight">{!DAY(TODAY())}</span><sup>st</sup></apex:outputText>
