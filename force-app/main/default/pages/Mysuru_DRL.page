                    <td>{!Booking__c.Project_Address__c}</td>
                </tr>
                <tr>
                    <td width="30%">Plan Sanctioned for</td>
                    <td>{!totalAmountstring}</td>
                </tr>
                <tr>
                    <td width="30%">Present Stage of Construction</td>
                    <td>{!stageName}</td>
                </tr>
            </table><br/>
