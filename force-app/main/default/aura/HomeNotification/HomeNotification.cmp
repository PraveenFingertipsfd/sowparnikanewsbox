                                <div class="slds-grid slds-wrap">
                                    <aura:iteration items="{!v.nofollowuplist}" var="leadRecord">
                                        <!-- Render only the rows for the current page -->
                                        <div class="slds-col slds-size_1-of-5 slds-p-around_x-small">
                                            <div class="slds-grid slds-align-top">
                                                <div class="slds-box">
                                                    <lightning:card title="{!'Lead ID: ' + leadRecord.Lead_ID__c}" iconName="standard:opportunity_contact_role" >
                                                        <aura:set attribute="actions">
