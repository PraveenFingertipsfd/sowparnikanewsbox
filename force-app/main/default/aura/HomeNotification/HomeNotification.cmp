                                <lightning:buttonGroup aura:id="paginationButtons">
                                    <lightning:button label="Previous" onclick="{!c.NofollowuppreviousPage}" disabled="{!v.isNofollowupPreviousDisabled}" />
                                    <lightning:button label="{!v.NofollowupcurrentPage}" disabled="true" />
                                    <lightning:button label="Next" onclick="{!c.NofollowupnextPage}" disabled="{!v.isNofollowupNextDisabled}" />
                                </lightning:buttonGroup>
                            </div>
                        </div>
                        
                    </div>
                </div>
            </lightning:tab>
            <lightning:tab label="Reassigned Leads" aura:id="reassignLeds" id="reassignLeds">
                <div class="slds-m-around_x-small  slds-scrollable">
                    <div class="Button">
                        <div class="slds-form_horizontal slds-form slds-grid slds-wrap  ">
                            <div
                                 class="SVButton slds-size_1-of-3"
                                 style="background-color:#0176D3;padding:10px;border-radius:5px;color:white;margin:10px;text-align:center"
                                 >
                                {!'Reassigned Leads: '+ v.reassignCount}
                            </div>
                            
                        </div>
                    </div>
                    <div class="Cards slds-m-around_x-small " >
                        <div class="slds-p-around_medium" style="background-color: #FFFF;">
                            <div class="slds-p-around_medium">
                                <div class="slds-grid slds-wrap">
                                    <aura:iteration items="{!v.leadDetails}" var="leadRecord">
                                        <!-- Render only the rows for the current page -->
                                        <div class="slds-col slds-size_1-of-5 slds-p-around_x-small">
                                            <!-- <div class="{! 'slds-box slds-grid slds-align-top ' + (leadRecord.Lead_Type__c == 'Re-Engaged' ? 'green-background' : '')}">
                            <lightning:icon iconName="standard:opportunity_contact_role" size="small" alternativeText="Lead Icon" class="slds-m-right_x-small custom-icon"/>
                            <div class="slds-col">
                                <a onclick="{!c.navigateToLeadRecord}" data-recordId="{!leadRecord.Id}" style="color: #0070d2;">Lead ID : <u><b>{!leadRecord.Lead_ID__c}</b></u></a>
                                <p> Lead Name : <b><span >{!leadRecord.Name}</span></b></p>
                                <p> Lead Status : <b>{!leadRecord.Status}</b></p>
                                <p> Project Name : <b>{!leadRecord.Allocated_Project__c}</b></p>
                                <p> Primary Phone : <b>{!leadRecord.Phone__c}</b></p>
                               <p> Lead Source : <b>{!leadRecord.Lead_source__c}</b></p>
                            </div>
                        </div>-->
                                            <div class="slds-grid slds-align-top">
                                                <div class="slds-box">
                                                    <lightning:card title="{!'Lead ID: ' + leadRecord.Lead_ID__c}" iconName="standard:opportunity_contact_role" >
                                                        <aura:set attribute="actions">
                                                            <lightning:button label="View Details" variant="base" onclick="{!c.navigateToLeadRecord}" value="{!leadRecord.Id}" />
                                                        </aura:set>
                                                        <p class="slds-p-horizontal_small">Lead Name: <b>{!leadRecord.Name}</b></p>
                                                        <p class="slds-p-horizontal_small">Project Name: <b>{!leadRecord.Allocated_Project__c}</b></p>
                                                        <p class="slds-p-horizontal_small">Primary Phone: <b>{!leadRecord.Phone__c}</b></p>
                                                        <!-- Add more fields as needed -->
                                                    </lightning:card>
                                                </div>
                                            </div>
                                        </div>
                                    </aura:iteration>
                                </div>
                            </div>
                            <!-- Pagination Controls -->
                            <div class="slds-align_absolute-center slds-m-top_medium">
                                <lightning:buttonGroup aura:id="paginationButtons">
                                    <lightning:button label="Previous" onclick="{!c.NoActivitypreviousPage}" disabled="{!v.isNoActivityPreviousDisabled}" />
                                    <lightning:button label="{!v.NoActivitycurrentPage}" disabled="true" />
                                    <lightning:button label="Next" onclick="{!c.NoActivitynextPage}" disabled="{!v.isNoActivityNextDisabled}" />
                                </lightning:buttonGroup>
                            </div>
                        </div>
                        
                    </div>
                </div>
            </lightning:tab>
            <lightning:tab label="Booking's of The Day" aura:id="todaysbookings" id="bookings">
                <div class="slds-m-around_x-small  slds-scrollable">
                    <div class="Button">
                        <div class="slds-form_horizontal slds-form slds-grid slds-wrap  ">
                            <div
                                 class="SVButton slds-size_1-of-3"
                                 style="background-color:#0176D3;padding:10px;border-radius:5px;color:white;margin:10px;text-align:center"
                                 >
                                {!'Todays Total Bookings: '+ v.BookingLeadCount}
                            </div>
                            
                        </div>
                    </div>
                    <div class="Cards slds-m-around_x-small " >
                        <div class="slds-p-around_medium" style="background-color: #FFFF;">
                            <div class="slds-p-around_medium">
                                <div class="slds-grid slds-wrap">
                                    <aura:iteration items="{!v.bookingrecordList}" var="Record">
                                        <!-- Render only the rows for the current page -->
                                        <div class="slds-col slds-size_1-of-5 slds-p-around_x-small">
                                            <!-- <div class="{! 'slds-box slds-grid slds-align-top ' + (leadRecord.Lead_Type__c == 'Re-Engaged' ? 'green-background' : '')}">
                            <lightning:icon iconName="standard:opportunity_contact_role" size="small" alternativeText="Lead Icon" class="slds-m-right_x-small custom-icon"/>
                            <div class="slds-col">
                                <a onclick="{!c.navigateToLeadRecord}" data-recordId="{!leadRecord.Id}" style="color: #0070d2;">Lead ID : <u><b>{!leadRecord.Lead_ID__c}</b></u></a>
                                <p> Lead Name : <b><span >{!leadRecord.Name}</span></b></p>
                                <p> Lead Status : <b>{!leadRecord.Status}</b></p>
                                <p> Project Name : <b>{!leadRecord.Allocated_Project__c}</b></p>
                                <p> Primary Phone : <b>{!leadRecord.Phone__c}</b></p>
                               <p> Lead Source : <b>{!leadRecord.Lead_source__c}</b></p>
                            </div>
                        </div>-->
                                            <div class="slds-box">
                                                <lightning:card title="{!'Booking ID: ' + Record.Name}" iconName="standard:opportunity_contact_role" >
                                                    <aura:set attribute="actions">
                                                        <lightning:button label="View Details" variant="base" onclick="{!c.navigateToLeadRecord}" value="{!Record.Id}" />
                                                    </aura:set>
                                                    <p class="slds-p-horizontal_small">Booking Name: <b>{!Record.Name}</b></p>
                                                    <p class="slds-p-horizontal_small">Project Name: <b>{!Record.Project__c}</b></p>
                                                    <p class="slds-p-horizontal_small">Unit Number: <b>{!Record.Unit_NumberFor__c}</b></p>
                                                    <p class="slds-p-horizontal_small">Block: <b>{!Record.Block_Number__c}</b></p>
                                                    
                                                    <!-- Add more fields as needed -->
                                                </lightning:card>
                                            </div>
                                        </div>
                                        
                                    </aura:iteration>
                                </div>
                            </div>
                            <!-- Pagination Controls -->
                            <div class="slds-align_absolute-center slds-m-top_medium">
                                <lightning:buttonGroup aura:id="paginationButtons">
                                    <lightning:button label="Previous" onclick="{!c.BookingpreviousPage}" disabled="{!v.isBookingPreviousDisabled}" />
                                    <lightning:button label="{!v.BookingcurrentPage}" disabled="true" />
                                    <lightning:button label="Next" onclick="{!c.BookingnextPage}" disabled="{!v.isBookingNextDisabled}" />
                                </lightning:buttonGroup>
                            </div>
                        </div>
                        
                    </div>
                </div>
            </lightning:tab>
        </lightning:tabset>
        <aura:if isTrue="{!v.isCall}">
            <section
                     role="dialog"
                     tabindex="-1"
                     aria-labelledby="modal-heading-01"
                     aria-modal="true"
                     aria-describedby="modal-content-id-1"
                     class="slds-modal slds-fade-in-open"
                     >
                <div class="slds-modal__container">
                    <!-- Modal/Popup Box Header Starts here-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon
                                              iconName="utility:close"
                                              onclick="{!c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"
                                              />
                        <h2
                            id="modal-heading-01"
                            class="slds-text-heading_medium slds-hyphenate"
                            >Make Call</h2
                            >
                    </header>
                    <!--Modal/Popup Box Body Starts here-->
                    <div
                         class="slds-modal__content slds-p-around_medium"
                         id="modal-content-id-1"
                         >
                        <c:MakeCall recordId="{!v.leadRecID}" fromHome="true"  parent="{!this}" />
                    </div>
                    
                    <!--Modal/Popup Box Footer Starts here-->
                    <footer class="slds-modal__footer">
                        <lightning:button
                                          variant="neutral"
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModel }"
                                          />
                    </footer>
                </div>
            </section>
            <aura:if isTrue="{!v.isCall}">
                <div class="slds-backdrop slds-backdrop_open"></div>
            </aura:if>
        </aura:if>
        <!--Sv Status Change -->
        <aura:if isTrue="{!v.isSv}">
            <section
                     role="dialog"
                     tabindex="-1"
                     aria-labelledby="modal-heading-01"
                     aria-modal="true"
                     aria-describedby="modal-content-id-1"
                     class="slds-modal slds-fade-in-open"
                     >
                <div class="slds-modal__container">
                    <!-- Modal/Popup Box Header Starts here-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon
                                              iconName="utility:close"
                                              onclick="{! c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"
                                              />
                        <h2
                            id="modal-heading-01"
                            class="slds-text-heading_medium slds-hyphenate"
                            >
                            Change Site Visit Status
                        </h2>
                    </header>
                    <!--Modal/Popup Box Body Starts here-->
                    <div
                         class="slds-modal__content slds-p-around_medium"
                         id="modal-content-id-1"
                         >
                        <lightning:select
                                          aura:id="StatusID"
                                          name="select"
                                          label="Select a Status"
                                          onchange="{! c.onChange }"
                                          required="true"
                                          >
                            <option value="">Select the Status..</option>
                            <option value="Cancelled">Cancelled</option>
                        </lightning:select>
                        
                        <aura:if isTrue="{!v.isCancelled}">
                            
                            <lightning:textarea name="input3" label="Enter the Cancel Reason" placeholder="type here..." value="{!v.updateValue}" required="true"/>
                        </aura:if>
                        <aura:if isTrue="{!v.isConducted}">
                            <lightning:textarea name="input3" label="Enter the Comments" placeholder="type here..." value="{!v.updateValue}" required="true"/>
                        </aura:if>
                        <aura:if isTrue="{!v.isReschedule}">
                            <div> 
                                <lightning:input  aura:id="NextfollowUpDateID"  type="datetime" name="Reschedule Date" label="Reschedule Date" required="true"  value="{!v.updateValue}"/>
                                <br></br>
                                <br></br>
                                
                            </div>
                            
                        </aura:if>
                        
                    </div>
                    <!--Modal/Popup Box Footer Starts here-->
                    <footer class="slds-modal__footer">
                        <lightning:button
                                          variant="neutral"
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModel }"
                                          />
                        <lightning:button
                                          variant="brand"
                                          label="Update"
                                          title="Update"
                                          onclick="{! c.UpdateSvStatus }"
                                          />
                    </footer>
                </div>
            </section>
            <aura:if isTrue="{!v.isSv}">
                <div class="slds-backdrop slds-backdrop_open"></div>
            </aura:if>
        </aura:if>
        <!-- Follow up status Change -->
        <aura:if isTrue="{!v.isfls}">
            <section
                     role="dialog"
                     tabindex="-1"
                     aria-labelledby="modal-heading-01"
                     aria-modal="true"
                     aria-describedby="modal-content-id-1"
                     class="slds-modal slds-fade-in-open"
                     >
                <div class="slds-modal__container">
                    <!-- Modal/Popup Box Header Starts here-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon
                                              iconName="utility:close"
                                              onclick="{! c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"
                                              />
                        <h2
                            id="modal-heading-01"
                            class="slds-text-heading_medium slds-hyphenate"
                            >
                            Change Follow-Up Status
                        </h2>
                    </header>
                    <!--Modal/Popup Box Body Starts here-->
                    <div
                         class="slds-modal__content slds-p-around_medium"
                         id="modal-content-id-1"
                         >
                        <lightning:select
                                          aura:id="StatusID1"
                                          name="select"
                                          label="Select a Status"
                                          onchange="{! c.onChange1 }"
                                          required="true"
                                          >
                            <option value="">Select the Status..</option>
                            <option value="Scheduled">Scheduled</option>
                            <option value="Missed">Missed</option>
                            <option value="Completed">Completed</option>
                        </lightning:select>
                         <aura:if isTrue="{!v.isCompleted1}">
                            
                            <lightning:textarea name="input3" label="Enter the Feedback" placeholder="type here..." value="{!v.updateValue1}" required="true"/>
                        </aura:if>
                        <aura:if isTrue="{!v.isMissed1}">
                            
                            <lightning:textarea name="input3" label="Enter the Feedback" placeholder="type here..." value="{!v.updateValue1}" required="true"/>
                        </aura:if>
                    </div>
                    <!--Modal/Popup Box Footer Starts here-->
                    <footer class="slds-modal__footer">
                        <lightning:button
                                          variant="neutral"
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModel }"
                                          />
                        <lightning:button
                                          variant="brand"
                                          label="Update"
                                          title="Update"
                                          onclick="{! c.UpdateflsStatus }"
                                          />
                    </footer>
                </div>
            </section>
            <aura:if isTrue="{!v.isfls}">
                <div class="slds-backdrop slds-backdrop_open"></div>
            </aura:if>
            
        </aura:if>
    </div>
</aura:component>