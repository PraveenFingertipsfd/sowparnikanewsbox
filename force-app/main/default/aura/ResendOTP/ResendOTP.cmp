<aura:component controller = "resendOTPController" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    <aura:attribute name="name" type="string"/>
    <aura:attribute name="project" type="string"/>
    <aura:attribute name="otp" type="string"/>
    <aura:attribute name="simpleRecord" type="Object"/>
    <aura:attribute name="recordError" type="String"/>
    <aura:attribute name="isLoaded" type="Boolean"/>
    <force:recordData aura:id="recordLoader"
                      fields="Name,Allocated_Project__c,Primary_Source_OTP__c,Phone__c,Is_Primary_User__c,Is_Secondary_Owner__c,Secondary_Source_OTP__c"
                      recordId="{!v.recordId}"
                      targetFields="{!v.simpleRecord}"
                      targetError="{!v.recordError}"
                      recordUpdated="{!c.doInit}"
                      />
    <div>
        <lightning:recordEditForm recordId="{!v.recordId}" objectApiName="Lead">
            <div class="slds-grid">
                <div class="slds-col slds-size_1-of-2">
                    <lightning:inputField fieldName="Name" disabled="true" value="{!v.name}"/>
                </div>
                &nbsp;
                <div class="slds-col slds-size_2-of-2">
                    <lightning:inputField fieldName="Allocated_Project__c" disabled="true" value="{!v.project}"/>
                </div>
            </div>
            <aura:if isTrue="{!v.simpleRecord.Is_Primary_User__c == true}">
                <div class="slds-grid">
                    <div class="slds-col slds-size_1-of-2">
                        <lightning:inputField fieldName="Primary_Source_OTP__c" disabled="true"/>
                    </div>
                    &nbsp;
                    <div class="slds-col slds-size_1-of-2">
                        <lightning:inputField fieldName="OwnerId" disabled="true"/>
                    </div>
                </div>
            </aura:if>
            <aura:if isTrue="{!v.simpleRecord.Is_Secondary_Owner__c == true}">
                <div class="slds-grid">
                    <div class="slds-col slds-size_1-of-2">
                        <lightning:inputField fieldName="Secondary_Source_OTP__c" disabled="true"/>
                    </div>
                    &nbsp;
                    <div class="slds-col slds-size_1-of-2">
                        <lightning:inputField fieldName="Lead_OwnerSecondary__c" disabled="true"/>
                    </div>
                </div>
            </aura:if>
        </lightning:recordEditForm>
    </div>
    <br/>
    <br/>
    <br/>
    <div>
         <button class="slds-button slds-button_brand" onclick="{!c.sendOTP}">Send OTP</button>
    </div>
</aura:component>