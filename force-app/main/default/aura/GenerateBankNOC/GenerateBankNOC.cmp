<aura:component controller="BookingWelcomeMail" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
	<aura:attribute name="recordId" type="string"/>
    <aura:attribute name="LeadRecord" type="Object"/>
    <aura:attribute name="bankName" type="string"/>
    <force:recordData aura:id="recordLoader"
                  recordId="{!v.recordId}"
                  fields="Name,OwnerId,Bank_Name__c"
                  recordUpdated="{!c.doInit}"
                  targetFields="{!v.LeadRecord}"
                  targetError="{!v.recordLoadError}"
                  />
    <aura:html tag="style">
        
        .panel.slds-modal > .modal-container{
        width: 75%;
        max-width: 70rem;
        }
    </aura:html>
    <section class="slds-modal slds-fade-in-open">
        <header class="slds-modal__header">
            <h2 class="slds-text-heading_medium slds-hyphenate">Generate NOC</h2>
        </header>
        <aura:if isTrue="{!v.bankName == 'SBI'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/BNOC_SBI?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'LT'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/BNOC_L_AND_T?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'HDFC'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/BNOC_HDFC?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'Tata Capital'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/BNOC_TataCapital?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'IIFL'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/BNOC_IIFL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
                <aura:if isTrue="{!v.bankName == 'ICICI'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/BNOC_ICICI?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        
        <footer class="slds-modal__footer">
            <button class="slds-button slds-button_neutral" onclick="{!c.close}">Cancel</button>            
        </footer>
    </section>
</aura:component>