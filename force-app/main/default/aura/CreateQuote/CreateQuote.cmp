<aura:component controller="CreateQuoteController" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickActionwithoutHeader" access="global"  >
    <aura:attribute name="plots" type="object[]" default="[]" access="global"/>
    <aura:attribute name="blocks" type="object[]" default="[]" access="global"/>
    <aura:attribute name="OppRecord" type="object[]" default="[]" access="global"/>
    <aura:attribute name="matchplots" type="Object[]" default="[]"/>
    <aura:attribute name="matchblocks" type="Object[]" default="[]"/>
    <aura:attribute name="searchText1" type="string" default=""/>
    <aura:attribute name="searchText2" type="string" default=""/>
    <aura:attribute name="showCostSheet" type="Boolean" default="False" />
    <aura:attribute name="showUnits" type="Boolean" default="False" />
    <aura:attribute name="Showfields" type="Boolean" default="False" />
    
    <aura:attribute name="options" type="List[]" />
    <aura:attribute name="optionsUser" type="List[]" />
    <aura:attribute name="selectedValues" type="List"   default="" description="Selected value in Multi Select" />
    
    <aura:attribute name = "parkingType" type="String"/>
    <aura:attribute name = "openParking" type="Decimal"/>
    <aura:attribute name = "schemeAmount" type="Decimal"/>
    <aura:attribute name = "closeParking" type="Decimal"/>
    <aura:attribute name = "basicParking" type="Decimal"/>
    <aura:attribute name = "newBasicprice" type="Decimal"/>
    <aura:attribute name = "newConstructionCost" type="Decimal"/>
    <aura:attribute name = "totalOfFlat" type="Decimal"/>
    <aura:attribute name="TotalPriceWithoutExRege" type="Decimal"/>
    <aura:attribute name="TotalWithoutBookingAmont" type="Decimal"/>
    <aura:attribute name="bookingAmount" type="Decimal"/>
    <aura:attribute name="bookingAmountLimit" type="Decimal"/>
    <aura:attribute name="originalValue" type="Decimal"/>
    <aura:attribute name="isDisabled" type="Boolean" default="false" />
    
    <aura:attribute name="isApartment" type="Boolean" default="False" />
    <aura:attribute name="isNotApartment" type="Boolean" default="False" />
    
    <aura:attribute name="quoteId" type="string" default=""/>
    <aura:attribute name="recordId" type="Id" default=""/>
    <aura:attribute name="projectName" type="String" />
    <aura:attribute name="flatNumber" type="String" />
    <aura:attribute name="blockId" type="String" />
    <aura:attribute name="FlatCost" type="Decimal" default="0.00"/>
    <aura:attribute name="GrandTotal" type="Decimal"/>
    <aura:attribute name="afterDiscount" type="Decimal"/>
    <aura:attribute name="oppPlot" type="Booking__c"  default="{}"/>
    <aura:attribute name="paymentType" type="String" />
    <aura:attribute name="spinner" type="boolean" default="false"/>
    <aura:attribute name="paymentTypePicklist" type="String[]" />
    <aura:attribute name="today" type="Date" />
    <aura:attribute name="RecTypeId" type="String"/>
    <aura:attribute name="showNextCmp" type="boolean" default="false" />
    <aura:attribute name="showPaymentSchCmp" type="Boolean" default="false" />
    <aura:attribute name="paymentSchedules" type="Payment_schedule__c[]"/>
    <aura:attribute name = "CustompaymentSchedules" type="object[]"/>
    <aura:attribute name="RecivedAmountTotal" type="Decimal" default="0.00"/>
    <aura:attribute name="totalPercent" type="Decimal" default="0.00"/>
    <aura:attribute name="GrandTotalwithGST" type="Decimal" default="0.00"/>
    <aura:handler name="change" value="{!v.selectedValues}" action="{!c.handleMultiSelectChange}" />

    <aura:handler name="change" value="{!v.searchText1}" action="{!c.searchText1}"></aura:handler>
    <aura:handler name="change" value="{!v.searchText2}" action="{!c.searchText2}"></aura:handler>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"></aura:handler>
    <aura:html tag="style">
        .slds-modal__container{ 
        max-width: 80rem !important;
        width:80% !important;
        } 
        
        .cuf-content {
        padding: 0 0rem !important;
        }
        .slds-p-around--medium {
        padding: 0rem !important;
        }
        .slds-modal__content{
        
        height:unset !important;
        max-height:unset !important;
        }
        
        .closeIcon{
        display:none;
        }
        .slds-col{
        margin-left:5px;
        }
    </aura:html >
    <aura:if isTrue="{!Not(v.showNextCmp)}"> 
        <header class="slds-modal__header">
            <lightning:buttonIcon iconName="utility:close"
                                  onclick="{! c.closeModel }"
                                  alternativeText="close"
                                  variant="bare-inverse"
                                  class="slds-modal__close"/>
            <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">New Quote</h2>
        </header>
        <div class="slds-grid slds-wrap slds-grid_pull-padded-x-medium">
            <!-- **************************************************************************************************** -->
            <div class="slds-size_4-of-8 slds-p-horizontal_small">
                <div class="slds-combobox_container">
                    <div class="{!not(empty(v.matchblocks)) ? 'slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click slds-is-open' : 'slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click' }" aura:id="open">
                        <div class="slds-combobox__form-element slds-input-has-icon slds-input-has-icon_right" role="none">
                            <lightning:input value="{!v.searchText2}" aura:id="field1" name="enter-search" label="Block" type="search" required="true" id="combobox-id-1" aria-autocomplete="list" aria-controls="listbox-id-1" aria-expanded="false" aria-haspopup="listbox" autoComplete="off" role="combobox" placeholder="Search..."/>                                      
                        </div>
                        <div id="listbox-id-1" class="slds-dropdown slds-dropdown_length-with-icon-7 slds-dropdown_fluid" role="listbox">
                            <ul class="slds-listbox slds-listbox_vertical" role="presentation">
                                <aura:if isTrue="{!v.matchblocks}">
                                    <!--<div class="{!if(not(empty(v.matchblocks)), 'result-buttom','')}">-->
                                    <aura:iteration items="{!v.matchblocks}" var="item">
                                        <li role="presentation" class="slds-listbox__item">
                                            <div id="option1" class="slds-media slds-listbox__option slds-listbox__option_entity slds-listbox__option_has-meta" role="option">
                                                <span class="slds-media__figure slds-listbox__option-icon">
                                                    <span class="slds-icon_container slds-icon-standard-account">
                                                        <lightning:icon iconName="standard:user" size="xx-small"/>&nbsp;
                                                    </span>
                                                </span>
                                                <span class="slds-media__body">
                                                    <div class="slds-lookup__result-text" data-id="{!item.Id}" onclick="{!c.update2}">
                                                        <span class="slds-listbox__option-text slds-listbox__option-text_entity">{!item.Name}</span>
                                                        <!--<span class="slds-listbox__option-meta slds-listbox__option-meta_entity">Account • Burlington, NC</span>-->
                                                    </div>
                                                </span>
                                            </div>
                                        </li>
                                    </aura:iteration> 
                                </aura:if>      
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <!-- **************************************************************************************************  -->
            <aura:if isTrue="{!v.showUnits == true}">
                <div class="slds-size_4-of-8 slds-p-horizontal_small">
                    <div class="slds-combobox_container">
                        <div class="{!not(empty(v.matchplots)) ? 'slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click slds-is-open' : 'slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click' }" aura:id="open">
                            <div class="slds-combobox__form-element slds-input-has-icon slds-input-has-icon_right" role="none">
                                <lightning:input value="{!v.searchText1}" aura:id="field1" name="enter-search" label="Unit Number" type="search" required="true" id="combobox-id-1" aria-autocomplete="list" aria-controls="listbox-id-1" aria-expanded="false" aria-haspopup="listbox" autoComplete="off" role="combobox" placeholder="Search..."/>                                      
                            </div>
                            <div id="listbox-id-1" class="slds-dropdown slds-dropdown_length-with-icon-7 slds-dropdown_fluid" role="listbox">
                                
                                <ul class="slds-listbox slds-listbox_vertical" role="presentation">
                                    <aura:if isTrue="{!v.matchplots}">
                                        <!--<div class="{!if(not(empty(v.matchplots)), 'result-buttom','')}">-->
                                        <aura:iteration items="{!v.matchplots}" var="item">
                                            <li role="presentation" class="slds-listbox__item">
                                                <div id="option1" class="slds-media slds-listbox__option slds-listbox__option_entity slds-listbox__option_has-meta" role="option">
                                                    
                                                    <span class="slds-media__figure slds-listbox__option-icon">
                                                        <span class="slds-icon_container slds-icon-standard-account">
                                                            <lightning:icon iconName="standard:user" size="xx-small"/>&nbsp;
                                                        </span>
                                                    </span>
                                                    <span class="slds-media__body">
                                                        <div class="slds-lookup__result-text" data-id="{!item.Id}" onclick="{!c.update1 }">
                                                            <span class="slds-listbox__option-text slds-listbox__option-text_entity">{!item.Name}</span>
                                                            <!--<span class="slds-listbox__option-meta slds-listbox__option-meta_entity">Account • Burlington, NC</span>-->
                                                        </div>
                                                    </span>
                                                </div>
                                            </li>
                                        </aura:iteration> 
                                    </aura:if>      
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </aura:if>
            <aura:if isTrue="{!v.searchText1!=''}">
                <aura:if isTrue="{!v.Showfields}">
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="Project__c" type="Text" formatter="Text"  disabled="true" label="Project" aura:id="pro" value="{!v.oppPlot.Project__c}" />
                    </div> 
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="Quote_date__c" type="Date" formatter="Date" step="0.01" disabled="true" label="Quote Date" default="{!v.today}" value="{!v.oppPlot.Quote_date__c}" />
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="Property_Type__c" type="Text" formatter="Text"  disabled="true" label="Property Type"  value="{!v.oppPlot.Property_Type__c}" />
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="Corner__c" type="Text" formatter="Text"  disabled="true" label="Corner"  value="{!v.oppPlot.Corner__c}" />
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="BHK_Type__c" type="Text" formatter="Text"  disabled="true" label="BHK"  value="{!v.oppPlot.BHK_Type__c}" />
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="Unit_Facing_Direction__c" type="Text" formatter="Text" disabled="true" label="Unit Facing Direction"  value="{!v.oppPlot.Unit_Facing_Direction__c}" />
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="Basic_Price__c" type="number" formatter="currency"  disabled="true" label="Rate Per Sqft"   value="{!v.oppPlot.Rate_per_sqft__c}" onchange="{!c.handleInputChange}"/>
                    </div>
                     <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="Basic_Price__c" type="number" formatter="currency"  disabled="true" label="Floor Raise"   value="{!v.oppPlot.Floor_Raise__c}" onchange="{!c.handleInputChange}"/>
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small">
                        <lightning:input name="Built_up_area__c" type="number" disabled="true"  formatter="number" label="Built up Area"  value="{!v.oppPlot.Built_up_area__c}" />
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small">
                        <lightning:input name="Plot_Land_Area__c" type="number" disabled="true"  formatter="currency" label="Plot Land Area"  value="{!v.oppPlot.Plot_Land_Area__c}" onchange="{!c.handleInputChange}"/>
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small">
                        <lightning:input name="Undivided_Share_of_Land__c" type="number" disabled="true"  formatter="number" label="Undivided Share of Land"  value="{!v.oppPlot.Undivided_Share_Of_Land__c}" />
                    </div>
                    <aura:if isTrue="{!v.isApartment == false}">
                        <div class="slds-size_4-of-8 slds-p-horizontal_small">
                            <lightning:input name="Construction_Cost__c" type="number" disabled="true"  formatter="currency" label="Construction Cost"  value="{!v.oppPlot.Construction_Cost__c}" onchange="{!c.handleInputChange}"/>
                        </div>
                        <div class="slds-size_4-of-8 slds-p-horizontal_small">
                            <lightning:input name="Land_Cost__c" type="number" disabled="true"  formatter="number" label="Land Cost"  value="{!v.oppPlot.Land_Cost__c}" />
                        </div>
                    </aura:if>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="Club_House__c" type="number" formatter="currency"  disabled="true" label="Club and Amenities Charges"    value="{!v.oppPlot.Club_Amenities_Charges__c}" onchange="{!c.handleInputChange}"/>
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="Corpus_Fund__c" type="number" formatter="currency"  disabled="true" label="Water and Electricity Charges"   value="{!v.oppPlot.Water_Electricity_Charges__c}" onchange="{!c.handleInputChange}"/>
                    </div>
                    
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:select class="select slds-size_1-of-1" label="Parking Type" disabled="{!v.isDisabled}" aura:id="parKingType" onchange="{!c.handleChangeCarParking}" value="{!v.parkingType}">
                            <option value="None" >None</option>
                            <option value="Open" >Open Parking</option>
                            <option value="Closed" >Closed Parking</option>
                        </lightning:select>
                    </div>
                    
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:input name="Legal_Documentation_Charges__c" type="number" formatter="currency"  disabled="true" label="Car/Scooter Parking"  value="{!v.oppPlot.Car_Scooter_Parking__c}" onchange="{!c.handleInputChange}"/>
                    </div>
                    
                    <div class="slds-size_4-of-8 slds-p-horizontal_small">
                        <lightning:input name="Infrastructure_Charges_per_sqft__c" type="number" disabled="true"  formatter="currency" label="Generator/STP"  value="{!v.oppPlot.Generator_STP__c}" onchange="{!c.handleInputChange}"/>
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small">
                        <lightning:input name="Premium_Location_Charge__c" type="number" disabled="true"  formatter="currency" label="PLC Charges"  value="{!v.oppPlot.PLC__c}" onchange="{!c.handleInputChange}"/>
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small">
                        <lightning:input name="GST1__c" type="number" disabled="true"   label="GST%"  value="{!v.oppPlot.GST1__c}" />
                    </div>
                    
                    <div class="slds-size_4-of-8 slds-p-horizontal_small">
                        <lightning:input name="GRAND_TOTAL__c" type="number" formatter="currency" disabled="true"   label="Labour Cess"  value="{!v.oppPlot.Labour_Cess__c}" />
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small">
                        <c:MultiSelectComboBox options="{!v.options}" values="{!v.selectedValues}"  label="Select the Scheme" multiSelect="true" searchString="" />
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small">
                        <lightning:input name="GRAND_TOTAL__c" type="number" disabled="false" required="true"  label="Booking Amount"  value="{!v.bookingAmount}"  />
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small">
                        <lightning:input name="GRAND_TOTAL__c" type="number" disabled="true"   label="Total Cost (Ex. Leg. &amp; Main.)"  value="{!v.TotalPriceWithoutExRege}" />
                    </div>
                    <div class="slds-size_4-of-8 slds-p-horizontal_small"  >
                        <lightning:select class="select slds-size_1-of-1" label="Payment Type"  aura:id="select" value="{!v.oppPlot.Payment_Type__c}"   messageWhenValueMissing="Please select this field" disabled="false"  required="true" onchange="{!c.handleChange}">
                            <option value="None" >None</option>
                            <aura:iteration items="{!v.paymentTypePicklist}"  var="option">
                                <option text="{!option}" ></option>
                            </aura:iteration>
                        </lightning:select>
                    </div>
                        <div class="slds-size_4-of-8 slds-p-horizontal_small">
                            <lightning:input name="Discount__c" type="number" aura:id = "discountCalculations" formatter="currency" step="0.01" label="Discount Given (Rate per sqft)"  value="{!v.oppPlot.Discount__c}" onchange="{!c.discountCalculation}"/>
                        </div>
                     <div class="slds-size_4-of-8 slds-p-horizontal_small">
                            <lightning:input name="CP_Discount__c" type="number"  formatter="currency" step="0.01" label="CP Discount Given (Rate per sqft)"  value="{!v.oppPlot.CP_Discount__c}"/>
                        </div>
                    <br>
                    </br>
                </aura:if>
            </aura:if>
            <br>
            </br>
            <br>
            </br> 
        </div>
        <div class="modal-footer slds-modal__footer slds-size_1-of-1">
            <button class="slds-button slds-button_brand" onclick="{!c.closeModel}">Cancel</button>
            <lightning:button class="slds-m-top_small" variant="brand"  label="Next"  onclick="{!c.navigateToPaymentSchedule}"/>            
        </div>
    </aura:if> 
    <aura:if isTrue="{!v.showNextCmp}">
        <!--<c:PaymentSchCmp Pay="{!v.oppPlot.Payment_Type__c}" project="{!v.oppPlot.Project__c}"  oppPlot="{!v.oppPlot}"/> -->
        <div role="dialog" tabindex="-1" aria-labelledby="header43" aura:id="Modalbox" class="slds-modal slds-fade-in-open">
            <div class="slds-modal__container">
                <div class="modal-header slds-modal__header slds-size_1-of-1">
                    <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate"> Payment schedules</h2><br/><br/>
                    <b>Project Name:</b>&nbsp;&nbsp; {!v.projectName} &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <b>Flat Number:</b>&nbsp;&nbsp; {!v.flatNumber}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                    <aura:if isTrue = "{!v.paymentType == 'Standard'}">  
                        <span class="red-dot"></span> - to be merged
                    </aura:if>
                </div>
                <aura:if isTrue = "{!v.paymentType == 'Standard'}">         
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1" >
                        <div class="slds-scrollable"   style="height:auto">
                            <table   class="slds-table slds-table_cell-buffer slds-table_bordered" aria-label="">
                                <thead>
                                    <tr class="slds-line-height_reset">
                                        <th scope="col"><div class="slds-truncate" title="Name">Sl. No</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Name">Payment Schedule Name</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Name">Percent</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Name">Amount</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Name">Status</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Name">Due Date</div></th>
                                        <!--<th scope="col"><div class="slds-truncate" title="Name">Is Completed</div></th>-->
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration items="{!v.paymentSchedules}" var="item" indexVar="index">
                                        <tr class="{! 'slds-hint-parent ' + (item.status__c == 'Completed' ? 'completed-row' : '')}">
                                            <td><div class="slds-truncate" title="{!index+1}">{!index +1}</div></td>
                                            <td><div class="slds-truncate" title="{!item.Name}">{!item.Name}</div></td>         
                                            <td><div class="slds-truncate" title="{!item.Payment_percent__c}">{!item.Payment_percent__c}</div></td>    
                                            <td><div class="slds-truncate" title="{!item.Amount__c}">{!item.Amount__c}</div></td>
                                            <td><div class="slds-truncate" title="{!item.status__c}">{!item.status__c}</div></td>
                                            <td>
                                                <aura:if isTrue = "{!item.status__c == 'Completed'}">   
                                                    <div class="slds-truncate" title="{!item.Payment_Due_Date__c}"><lightning:input type="date" name="input6" label="Due Date"  value="{!item.Payment_Due_Date__c}" onchange="{!c.fillDueDate}"/>
                                                    </div>
                                                </aura:if>
                                            </td>
                                            <!-- <td><div class="slds-truncate" title="{!item.Completed__c}"> <lightning:input type="Checkbox"   disabled="true" name="input6"   checked="{!item.Completed__c}"/></div></td> -->
                                        </tr>
                                    </aura:iteration>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </aura:if> 
                <aura:if isTrue = "{!v.paymentType == 'Custom'}">         
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1" >
                        <div class="slds-scrollable"   style="height:auto">
                            <table   class="slds-table slds-table_cell-buffer slds-table_bordered" aria-label="">
                                <thead>
                                    <tr class="slds-line-height_reset">
                                        <th scope="col"><div class="slds-truncate" title="Name">Sl. No</div></th>
                                        <th scope="col" ><div class="slds-truncate" title="Name">Payment Schedule Name</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Name">Amount</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Name">Percent</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Name">Status</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Name">Date</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Name">Add/Delete</div></th>
                                        <!-- <th scope="col"><div class="slds-truncate" title="Name">Is Completed</div></th> -->
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration items="{!v.CustompaymentSchedules}" var="item" indexVar="index">
                                        <tr class="slds-hint-parent">
                                            <td><div class="slds-truncate" title="{!index+1}" >{!index +1}</div></td>
                                            <td ><div class="slds-truncate" title="{!item.Name}"><lightning:input type="text" name="input6" label="Name"  value="{!item.Name}"/></div></td>         
                                            <td><div class="slds-truncate" title="{!item.Payment_percent__c}"><lightning:input type="number" name="input6" label="Percent"  value="{!item.Payment_percent__c}"/></div></td>  
                                            <td >
                                                <div class="slds-truncate" title="{!item.status__c}"><lightning:select name="select1" label="status" value="{!item.status__c}">
                                                    <option value="">choose one...</option>
                                                    <option value="Scheduled">Scheduled</option>
                                                    <option value="Demanded">Demanded</option>
                                                    <option value="Paid">Paid</option>
                                                    </lightning:select></div>
                                            </td> 
                                           <!-- <td>
                                                <aura:if isTrue = "{!item.status__c == 'Scheduled' || item.status__c == 'Demanded'}">   
                                                    <div class="slds-truncate" title="{!item.Payment_Due_Date__c}"><lightning:input type="date" name="input6" label="Due Date"  value="{!item.Payment_Due_Date__c}"/>
                                                    </div>
                                                </aura:if>
                                                <aura:if isTrue = "{!item.status__c == 'Paid'}">   
                                                    <div class="slds-truncate" title="{!item.Completed_Date__c}"><lightning:input type="date" name="input6" label="Completed Date"  value="{!item.Completed_Date__c}"/>
                                                    </div>
                                                </aura:if>
                                            </td>--> 
                                            <td class="slds-text-align_right">
                                                <div class="slds-truncate">
                                                    <a onclick="{!c.removeRow}" data-record="{!index}">
                                                        <lightning:buttonIcon iconName="utility:delete" iconClass="red"  size="x-large" variant="destructive" alternativeText="Delete" />
                                                    </a>
                                                    <lightning:buttonIcon iconName="utility:add" iconClass="green"  size="x-large" variant="success" alternativeText="Add" onclick="{!c.addRow}"/>     
                                                </div></td>
                                            <!-- <td><div class="slds-truncate" title="{!item.Completed__c}"> <lightning:input type="Checkbox"   disabled="true" name="input6"   checked="{!item.Completed__c}"/></div></td> -->
                                        </tr>
                                    </aura:iteration>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </aura:if>         
                <div class="slds-modal__footer">
                    <b>Grand Total :</b>₹{!v.TotalPriceWithoutExRege}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                    <div class="slds-align_absolute-center slds-p-top_small "></div>
                    <lightning:button variant="brand" label="Previous" title="Brand action" onclick="{!c.handlePrevious}" />
                    <lightning:button  variant="brand" label="Save" title="Brand action" onclick="{!c.doSave}" />
                </div>
            </div>
        </div>
    </aura:if>
    <div>
        <aura:if isTrue="{!v.spinner}">
            <lightning:spinner class="spins" size="large" variant="brand" alternativeText="Loading" />
        </aura:if>
    </div>
    
</aura:component>