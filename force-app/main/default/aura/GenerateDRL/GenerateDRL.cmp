<aura:component controller="BookingWelcomeMail" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
	<aura:attribute name="recordId" type="string"/>
    <aura:attribute name="LeadRecord" type="Object"/>
    <aura:attribute name="bankName" type="string"/>
    <force:recordData aura:id="recordLoader"
                  recordId="{!v.recordId}"
                  fields="Name,OwnerId,Branch_Name__c"
                  recordUpdated="{!c.doInit}"
                  targetFields="{!v.LeadRecord}"
                  targetError="{!v.recordLoadError}"
                  />
    <aura:html tag="style">
        
        .panel.slds-modal > .modal-container{
        width: 75%;
        max-width: 70rem;
        }
    </aura:html>
    <section class="slds-modal slds-fade-in-open">
        <header class="slds-modal__header">
            <h2 class="slds-text-heading_medium slds-hyphenate">Generate DRL</h2>
        </header>
        <aura:if isTrue="{!v.bankName == 'Banaswadi'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/Banasadi_DRL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'Basavangudi'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/Basvangudi_DRL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'HSR'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/HSR_DRL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'Kormangala'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/Kormangla_DRL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'Malleshwaram'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/Malleshwaram_DRL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'Shankarpuram'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/Shankarpuram_DRL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'St marks'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/StMarks_DRL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'WhiteField'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/WhiteField_DRL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'Yelahanka'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/Yelahanka_DRL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        <aura:if isTrue="{!v.bankName == 'Mysuru'}">
            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <iframe src="{!'/apex/apex/Mysuru_DRL?Id=' + v.recordId }" width="100%" height="500px;" frameBorder="0"/> 
        </div>
        </aura:if>
        
        <footer class="slds-modal__footer">
            <button class="slds-button slds-button_neutral" onclick="{!c.close}">Cancel</button>            
        </footer>
    </section>
</aura:component>