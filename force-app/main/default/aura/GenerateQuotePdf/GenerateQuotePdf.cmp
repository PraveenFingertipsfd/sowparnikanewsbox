<aura:component controller="quotePdfController"
				implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickActionWithoutHeader" access="global" >     <aura:handler name="init" value="{!this}" action="{!c.doInit}"></aura:handler>
    	  <aura:attribute name="recordId" type="Id" />
    <aura:attribute name="vfPage" type="string" />
    <aura:attribute name="showPdf" type="boolean" default="false" />
    <aura:attribute name="appartement" type="boolean" default="false" />
    <aura:attribute name="notApartment" type="boolean" default="false" />
    <aura:attribute name="showAll" type="boolean" default="false" />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"></aura:handler>
     <aura:html tag="style">
        .panel.slds-modal > .modal-container{
        width: 75%;
        max-width: 70rem;
        }
    </aura:html>
    <aura:if isTrue = "{!v.showAll == true}">
    <section class="slds-modal slds-fade-in-open">
        <header class="slds-modal__header">
            <h2 class="slds-text-heading_medium slds-hyphenate">SOWPARNIKA QUOTATION</h2>
        </header>
        <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
            <aura:if isTrue="{!v.appartement}">
                
                <iframe src="{!'https://app-momentum-7695.my.salesforce.com/apex/AppartmentCostSheet?Id=' + v.recordId + '#view=fitH' }" width="100%" height="500px;" frameBorder="0"/> 
                
            </aura:if>
            <aura:if isTrue="{!v.notApartment}">
                
                <iframe src="{!'https://app-momentum-7695.my.salesforce.com/apex/VillaCostSheet?Id=' + v.recordId + '#view=fitH' }" width="100%" height="500px;" frameBorder="0"/> 
                
            </aura:if>
        </div>
        
        <footer class="slds-modal__footer">
            <button class="slds-button slds-button_neutral" onclick="{!c.close}">Cancel</button>
           <!-- <button class="slds-button slds-button_brand" onclick="{!c.send}">Send Email</button>-->
            
        </footer>
    </section>
   </aura:if>
</aura:component>