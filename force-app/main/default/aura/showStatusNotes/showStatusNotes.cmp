<aura:component  implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    
    <aura:attribute name="recordId" type="String"  />
    <aura:attribute name="LeadRecord" type="Object"/>
    <aura:attribute name="isPrimary" type="boolean" default="false"/>
    <aura:attribute name="isSecondary" type="boolean" default="false"/>
    <aura:attribute name="isOther" type="boolean" default="false"/>
    <force:recordData aura:id="recordLoader"
                  recordId="{!v.recordId}"
                  fields="Name,OwnerId,Lead_OwnerSecondary__c"
                  recordUpdated="{!c.doInit}"
                  targetFields="{!v.LeadRecord}"
                  targetError="{!v.recordLoadError}"
                  />
    <article class="slds-card">
        <div class="slds-card__header slds-grid">
            <header class="slds-media slds-media_center slds-has-flexi-truncate">
                <div class="slds-media__figure">
                    <lightning:icon iconName="action:new_note" alternativeText="New note" title="New note" />
                </div>
                <div class="slds-media__body">
                    <h2 class="slds-card__header-title">
                        <a href="#" class="slds-card__header-link slds-truncate" title="Accounts">
                            <span>Status Change Comments</span>
                        </a>
                    </h2>
                </div>
            </header>
        </div>
        <div class="slds-card__body slds-card__body_inner">
            <lightning:recordViewForm recordId="{!v.recordId}" objectApiName="Lead">
                <div >
                    <aura:if isTrue="{!v.isPrimary == true}">
                        <aura:if isTrue="{!v.isOther == true}">
                            <label><b>Primary Notes:</b></label>
                        </aura:if>
                        <lightning:outputField variant='label-hidden' fieldName="Comments__c" />
                    </aura:if><br/><br/>
                    <aura:if isTrue="{!v.isSecondary == true}">
                        <aura:if isTrue="{!v.isOther == true}">
                            <label><b>Secondary Notes:</b></label>
                        </aura:if>
                        <lightning:outputField variant='label-hidden' fieldName="CommentsSecondary__c" />
                    </aura:if>
                </div>
            </lightning:recordViewForm>
        </div>
    </article>
</aura:component>